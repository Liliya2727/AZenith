<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_dialog_rounded">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Profile"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <!-- Item: Performance -->
    <LinearLayout
        android:id="@+id/item_performance"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_item_rounded"
        android:layout_marginBottom="10dp"
        android:padding="12dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_performance"
            android:background="@drawable/bg_icon_rounded"
            android:padding="8dp"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Performance"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:layout_marginStart="14dp" />
    </LinearLayout>

    <!-- Item: Balanced -->
    <LinearLayout
        android:id="@+id/item_balanced"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_item_rounded"
        android:layout_marginBottom="10dp"
        android:padding="12dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_balanced"
            android:background="@drawable/bg_icon_rounded"
            android:padding="8dp"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Balanced"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:layout_marginStart="14dp" />
    </LinearLayout>

    <!-- Item: Eco Mode -->
    <LinearLayout
        android:id="@+id/item_eco"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_item_rounded"
        android:padding="12dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_eco"
            android:background="@drawable/bg_icon_rounded"
            android:padding="8dp"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eco Mode"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:layout_marginStart="14dp" />
    </LinearLayout>

</LinearLayout>